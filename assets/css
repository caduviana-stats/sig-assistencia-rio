/* ==========================================================
   SIDEBAR - NOVA IDENTIDADE VISUAL
========================================================== */

.sidebar{

    position:fixed;

    left:18px;

    top:82px;

    width:320px;

    max-height:calc(100vh - 100px);

    overflow:auto;

    background:rgba(255,255,255,.97);

    backdrop-filter:blur(14px);

    border:1px solid #EEF2F7;

    border-radius:24px;

    box-shadow:0 18px 45px rgba(15,23,42,.12);

    padding:0;

}

.section{

    padding:20px 24px;

    border-bottom:1px solid #EEF2F7;

}

.section:last-child{

    border:none;

}

.section h2{

    font-family:Inter,sans-serif;

    font-size:13px;

    letter-spacing:.08em;

    font-weight:700;

    color:#334155;

    margin-bottom:18px;

    text-transform:uppercase;

}

.sidebar-title{

    font-size:18px;

    font-weight:700;

    margin-bottom:16px;

}


.layer-item{

    display:flex;

    align-items:center;

    justify-content:space-between;

    margin-bottom:18px;

    font-family:Inter;

    font-size:17px;

    font-weight:500;

    color:#24324B;

}

.layer-item:last-child{

    margin-bottom:0;

}

.layer-item>span:first-child{

    width:16px;

    height:16px;

    border-radius:50%;

    margin-right:14px;

}

.layer-item label{

    flex:1;

}


.layer-color{

    width:14px;

    height:14px;

    border-radius:50%;

}


.layer-cas{

    background:#F97316;

}


.layer-cras{

    background:#FACC15;

}


.layer-creas{

    background:#DC2626;

}


.layer-inss{

    background:#5B2C83;

}

/* ==========================================================
   SWITCHES DAS CAMADAS
========================================================== */

.layer-item input{

    appearance:none;

    width:48px;

    height:28px;

    background:#D7DEE7;

    border-radius:999px;

    cursor:pointer;

    transition:.25s;

    position:relative;

}

.layer-item input::before{

    content:"";

    position:absolute;

    left:3px;

    top:3px;

    width:22px;

    height:22px;

    border-radius:50%;

    background:white;

    box-shadow:0 3px 8px rgba(0,0,0,.15);

    transition:.25s;

}

.layer-item input:checked{

    background:#2F80ED;

}

.layer-item input:checked::before{

    transform:translateX(20px);

}

